<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <TraderKindDef>
    <defName>Visitor_Outcast_Standard</defName>
    <label>trader</label>
    <stockGenerators>

      <!-- Resources -->
      <li Class="StockGenerator_SingleDef">
        <thingDef>Silver</thingDef>
        <countRange>75~300</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>ComponentIndustrial</thingDef>
        <countRange>-2~5</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>ComponentSpacer</thingDef>
        <countRange>-3~2</countRange> <!-- ~30% chance for 1-2 -->
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>MedicineIndustrial</thingDef>
        <countRange>1~4</countRange>
      </li>
      <li Class="StockGenerator_SingleDef">
        <thingDef>MealSurvivalPack</thingDef>
        <countRange>3~6</countRange>
      </li>
      <li Class="StockGenerator_MultiDef">
        <thingDefs>
          <li>Cloth</li>
          <li>Chocolate</li>
        </thingDefs>
      </li>

      <!-- Drugs -->
      <li Class="StockGenerator_Category">
        <categoryDef>Drugs</categoryDef>
        <maxTechLevelGenerate>Spacer</maxTechLevelGenerate>
        <thingDefCountRange>-1~1</thingDefCountRange>
        <totalPriceRange>200~400</totalPriceRange>
      </li>

      <!-- Techprints -->
      <li Class="StockGenerator_Techprints">
        <countChances>
          <li>
            <count>1</count>
            <chance>0.5</chance>
          </li>
        </countChances>
      </li>

      <!-- Weapons -->
      <li Class="StockGenerator_MarketValue">
        <maxTechLevelGenerate>Spacer</maxTechLevelGenerate>
        <tradeTag>WeaponRanged</tradeTag>
        <countRange>0~1</countRange>
      </li>
      <li Class="StockGenerator_Category">
        <maxTechLevelGenerate>Spacer</maxTechLevelGenerate>
        <categoryDef>WeaponsMelee</categoryDef>
        <countRange>0~1</countRange>
      </li>

      <!-- Apparel -->
      <li Class="StockGenerator_MarketValue">
        <countRange>0~1</countRange>
        <tradeTag>BasicClothing</tradeTag>
        <maxTechLevelGenerate>Spacer</maxTechLevelGenerate>
      </li>
      <li Class="StockGenerator_Tag">
        <tradeTag>DITN_Uniforms</tradeTag>
        <countRange>1~3</countRange>
      </li>
      <li Class="StockGenerator_Tag">
        <tradeTag>DITN_Armor</tradeTag>
        <thingDefCountRange>1~2</thingDefCountRange>
        <countRange>-2~1</countRange> <!-- ~30% chance for a single armor piece -->
      </li>

      <!-- Buying -->
      <li Class="StockGenerator_BuyExpensiveSimple" />
      <li Class="StockGenerator_BuyTradeTag">
        <tag>Art</tag>
      </li>
      <li Class="StockGenerator_BuyTradeTag">
        <tag>MusicalInstrument</tag>
      </li>

    </stockGenerators>
  </TraderKindDef>

</Defs>
