<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>DITN_OfficerUniform</defName>
    <label>Outcast Officer Uniform</label>
    <description>A tailored duty uniform worn by commissioned Outcast officers. Cut to be presentable in formal settings while remaining durable enough for field use.</description>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Pawn/Humanlike/Clothes/OfficerUniform/OfficerUniform</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>1.5</drawSize>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.9,0.9,0.9)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.33,0.33,0.33,1)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65,1)</only>
        </li>
        <li>
          <weight>6</weight>
          <min>(0.3,0.3,0.3,1)</min>
          <max>(0.5,0.5,0.5,1)</max>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>DITN_OfficerUniforms</researchPrerequisite>
    </recipeMaker>
    <stuffCategories>
      <li>Fabric</li>
      <li>Leathery</li>
    </stuffCategories>
    <costStuffCount>80</costStuffCount>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <WorkToMake>4200</WorkToMake>
      <Mass>1.8</Mass>
      <StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0.20</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0.20</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>2</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <SocialImpact>0.05</SocialImpact>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Clothes/OfficerUniform/OfficerUniform</wornGraphicPath>
      <useWornGraphicMask>True</useWornGraphicMask>
      <layers>
        <li>OnSkin</li>
      </layers>
      <tags>
        <li>DITN_OfficerUniform</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
    </apparel>
    <techLevel>Industrial</techLevel>
    <thingCategories Inherit="False">
      <li>DITN_Uniforms</li>
    </thingCategories>
    <tradeTags>
      <li>Clothing</li>
      <li>DITN_Uniforms</li>
    </tradeTags>
    <uiIconScale>1.15</uiIconScale>
  </ThingDef>

	<ThingDef ParentName="HatMakeableBase">
    <defName>DITN_OfficerHat</defName>
    <label>Outcast Officer Headwear</label>
    <description>A structured cap worn by Outcast Officers. Bears rank and unit markings, allowing the wearer to be identified quickly as command personnel during engagements.</description>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Headgear/OfficerCap/OfficerCap</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>1.2</drawSize>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.9,0.9,0.9)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.33,0.33,0.33,1)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65,1)</only>
        </li>
        <li>
          <weight>6</weight>
          <min>(0.3,0.3,0.3,1)</min>
          <max>(0.5,0.5,0.5,1)</max>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>DITN_OfficerUniforms</researchPrerequisite>
    </recipeMaker>
    <stuffCategories>
      <li>Fabric</li>
      <li>Leathery</li>
    </stuffCategories>
    <costStuffCount>35</costStuffCount>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <WorkToMake>1600</WorkToMake>
      <Mass>0.1</Mass>
      <StuffEffectMultiplierArmor>0.15</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0.2</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0.2</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>0.8</EquipDelay>
    </statBases>
    <apparel>
      <bodyPartGroups>
        <li>UpperHead</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Headgear/OfficerCap/OfficerCap</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags>
        <li>DITN_OfficerUniform</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
      <canBeDesiredForIdeo>true</canBeDesiredForIdeo>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <useWornGraphicMask>True</useWornGraphicMask>
    </apparel>
    <techLevel>Industrial</techLevel>
    <thingCategories Inherit="False">
      <li>DITN_Headgear</li>
    </thingCategories>
    <tradeTags>
      <li>Clothing</li>
      <li>DITN_Uniforms</li>
    </tradeTags>
    <uiIconScale>1.15</uiIconScale>
  </ThingDef>

