<?xml version='1.0' encoding='utf-8'?>
<Defs>
  <ThingDef ParentName="ArmorMachineableBase">
    <defName>UFR_OfficerBulwarkArmor</defName>
    <label>Officer Bulwark Armor</label>
    <description>A Bulwark armor set finished for officer-grade wear. Offers equivalent protection to standard Bulwark while maintaining the appearance expected of command personnel.</description>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Armor/OfficerArmor/OfficerArmor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>UFR_OfficerBulwarkArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>UFR_FabricationBench</li>
      </recipeUsers>
    </recipeMaker>
    <costList>
      <Steel>60</Steel>
      <Plasteel>40</Plasteel>
      <ComponentIndustrial>3</ComponentIndustrial>
      <Gold>10</Gold>
    </costList>
    <statBases>
      <WorkToMake>52000</WorkToMake>
      <MaxHitPoints>320</MaxHitPoints>
      <Mass>8</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>0.94</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.42</ArmorRating_Blunt>
      <ArmorRating_Heat>0.52</ArmorRating_Heat>
      <Insulation_Cold>34</Insulation_Cold>
      <Insulation_Heat>10</Insulation_Heat>
      <EquipDelay>6</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.2</SlaveSuppressionOffset>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <shellRenderedBehindHead>True</shellRenderedBehindHead>
      <useWornGraphicMask>True</useWornGraphicMask>
      <layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <wornGraphicPath>Things/Pawn/Humanlike/Armor/OfficerArmor/OfficerArmor</wornGraphicPath>
      <tags Inherit="False">
        <li>UFR_Armor</li>
      </tags>
      <renderNodeProperties>
        <li Class="UnitedFront.PawnRenderNodePropertiesDecal">
          <nodeClass>UnitedFront.PawnRenderNodeDecal</nodeClass>
          <workerClass>UnitedFront.PawnRenderNodeWorkerDecal</workerClass>
          <parentTagDef>ApparelBody</parentTagDef>
          <baseLayer>92</baseLayer>
          <texPaths>
            <li>Things/Decals/commander</li>
          </texPaths>
          <visibleFacing>
            <li>South</li>
            <li>North</li>
          </visibleFacing>
          <drawData>
            <scale>0.110</scale>
            <defaultData>
              <layer>72</layer>
              <offset>(0,0,-0.155)</offset>
            </defaultData>
            <dataNorth>
              <layer>92</layer>
              <offset>(0,0,-0.148)</offset>
            </dataNorth>
            <bodyTypeScales>
              <Hulk>1.35</Hulk>
              <Fat>1.1</Fat>
              <Thin>0.9</Thin>
              <Female>1.05</Female>
            </bodyTypeScales>
          </drawData>
        </li>
      </renderNodeProperties>
    </apparel>
    <comps>
      <li Class="UnitedFront.CompPropertiesEditDecalMarker" />
    </comps>
    <techLevel>Spacer</techLevel>
    <thingCategories>
      <li>UFR_Armor</li>
    </thingCategories>
    <tradeTags>
      <li>Armor</li>
      <li>UFR_Armor</li>
    </tradeTags>
    <uiIconScale>1.15</uiIconScale>
  </ThingDef>
