<Defs>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>UFR_UFUniform_SuperHot</defName>
    <label>Outcast Uniform (Desert)</label>
    <description>A standard Outcast duty uniform adapted for extreme heat. Stripped to the minimum needed for function, with a light weave that resists heat buildup.</description>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Things/Pawn/Humanlike/Clothes/FieldUniformHell/FieldUniformHell</texPath>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>1.5</drawSize>
    </graphicData>
        <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.82,0.76,0.65)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.78,0.72,0.60)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.70,0.65,0.52)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>UFR_ExtremeWeatherUniforms</researchPrerequisite>
    </recipeMaker>
    <stuffCategories>
      <li>Fabric</li>
      <li>Leathery</li>
    </stuffCategories>
    <costStuffCount>150</costStuffCount>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToMake>5400</WorkToMake>
      <Mass>2.8</Mass>
      <StuffEffectMultiplierArmor>0.2</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>1.75</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>2</EquipDelay>
    </statBases>
    <apparel>
      <developmentalStageFilter>Child,Adult</developmentalStageFilter>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>Things/Pawn/Humanlike/Clothes/FieldUniformHell/FieldUniformHell</wornGraphicPath>
      <useWornGraphicMask>True</useWornGraphicMask>
      <layers>
        <li>OnSkin</li>
      </layers>
      <tags>
        <li>UFR_UFUniform</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
    </apparel>
    <techLevel>Industrial</techLevel>
    <thingCategories Inherit="False">
      <li>UFR_Uniforms</li>
    </thingCategories>
    <tradeTags>
      <li>Clothing</li>
      <li>UFR_Uniforms</li>
    </tradeTags>
    <uiIconScale>1.15</uiIconScale>
  </ThingDef>

