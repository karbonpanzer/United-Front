<?xml version='1.0' encoding='utf-8'?>
<Defs>
  <ThingDef ParentName="UFR_DecalBodyArmor_Heavy">
    <defName>UFR_HeavyBulwarkArmor</defName>
    <label>Heavy Bulwark Armor</label>
    <description>A reinforced Bulwark armor set with additional plating over the standard configuration. Heavier and slower than Bulwark armor, but substantially more resistant to incoming fire. Used by assault troops expected to absorb significant punishment.</description>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <texPath>Things/Pawn/Humanlike/Armor/HeavyArmor/HeavyArmor</texPath>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>UFR_HeavyBulwarkArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>UFR_FabricationBench</li>
      </recipeUsers>
    </recipeMaker>
    <costList>
      <Steel>80</Steel>
      <Plasteel>50</Plasteel>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>
    <statBases>
      <WorkToMake>56000</WorkToMake>
      <MaxHitPoints>340</MaxHitPoints>
      <Mass>11</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>1.06</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.45</ArmorRating_Blunt>
      <ArmorRating_Heat>0.54</ArmorRating_Heat>
      <Insulation_Cold>38</Insulation_Cold>
      <Insulation_Heat>12</Insulation_Heat>
      <EquipDelay>8</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <MoveSpeed>-0.20</MoveSpeed>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <shellRenderedBehindHead>True</shellRenderedBehindHead>
      <layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <wornGraphicPath>Things/Pawn/Humanlike/Armor/HeavyArmor/HeavyArmor</wornGraphicPath>
      <useWornGraphicMask>True</useWornGraphicMask>
      <soundWear>Wear_PowerArmor</soundWear>
      <soundRemove>Remove_PowerArmor</soundRemove>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
      <tags Inherit="False">
        <li>UFR_Armor</li>
      </tags>
    </apparel>
    <techLevel>Spacer</techLevel>
    <thingCategories>
      <li>UFR_Armor</li>
    </thingCategories>
    <tradeTags>
      <li>Armor</li>
      <li>UFR_Armor</li>
    </tradeTags>
    <uiIconScale>1.15</uiIconScale>
  </ThingDef>

