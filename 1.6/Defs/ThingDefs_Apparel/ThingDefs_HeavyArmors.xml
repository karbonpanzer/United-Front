          <workerClass>EOTF.Core.DecalSystem.PawnRenderNodeWorkerApparel</workerClass>
          <parentTagDef>ApparelBody</parentTagDef>
          <baseLayer>16</baseLayer>
          <texPaths>
            <li>Things/Decals/Infantry/Ringer</li>
          </texPaths>
          <visibleFacing>
            <li>South</li>
            <li>North</li>
          </visibleFacing>
          <drawData>
            <scale>0.120</scale>
            <defaultData>
              <layer>92</layer>
              <offset>(0,0,-0.155)</offset>
              
            </defaultData>
            <dataNorth>
              <layer>92</layer>
              <offset>(0,0,-0.148)</offset>
