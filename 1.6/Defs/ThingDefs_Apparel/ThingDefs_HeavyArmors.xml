    <costList>
      <Steel>90</Steel>
      <Plasteel>60</Plasteel>
      <ComponentIndustrial>5</ComponentIndustrial>
    </costList>
    <statBases>
      <WorkToMake>60000</WorkToMake>
      <MarketValue>800</MarketValue>
      <MaxHitPoints>340</MaxHitPoints>
      <Mass>11</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>1.06</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.48</ArmorRating_Blunt>
      <ArmorRating_Heat>0.56</ArmorRating_Heat>
      <Insulation_Cold>38</Insulation_Cold>
      <Insulation_Heat>12</Insulation_Heat>
      <EquipDelay>8</EquipDelay>
