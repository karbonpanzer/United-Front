<Defs>
  <ThingDef ParentName="ArmorMachineableBase">
    <defName>TRG_HeavyMarauderArmor</defName>
    <label>Heavy Marauder Armor</label>
    <description>A reinforced Marauder armor set with additional plating over the standard configuration. Heavier and slower than Marauder armor, but substantially more resistant to incoming fire. Used by assault troops expected to absorb significant punishment.</description>
    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <texPath>Things/Pawn/Humanlike/Armor/HeavyArmor/HeavyArmor</texPath>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>TRG_HeavyMarauderArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>7</Crafting>
      </skillRequirements>
