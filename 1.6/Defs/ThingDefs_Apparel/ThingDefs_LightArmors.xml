<?xml version='1.0' encoding='utf-8'?>
<Defs>
  <ThingDef ParentName="UFR_DecalBodyArmor_Light">
    <defName>UFR_BulwarkArmor</defName>
    <label>Bulwark Armor</label>
    <description>A hardened armor set with segmented Bulwark plates bonded over a ballistic underlayer. Covers the torso and upper arms. Used by uf infantry who expect direct fire contact.</description>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Armor/LightArmor/LightArmor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisite>UFR_BulwarkArmor</researchPrerequisite>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>UFR_FabricationBench</li>
      </recipeUsers>
    </recipeMaker>
    <costList>
      <Steel>60</Steel>
      <Plasteel>35</Plasteel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <statBases>
      <WorkToMake>48000</WorkToMake>
      <MaxHitPoints>300</MaxHitPoints>
      <Mass>8</Mass>
      <Flammability>0.4</Flammability>
      <ArmorRating_Sharp>0.92</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.4</ArmorRating_Blunt>
      <ArmorRating_Heat>0.5</ArmorRating_Heat>
      <Insulation_Cold>34</Insulation_Cold>
      <Insulation_Heat>10</Insulation_Heat>
      <EquipDelay>6</EquipDelay>
    </statBases>
    <apparel>
      <useWornGraphicMask>True</useWornGraphicMask>
      <wornGraphicPath>Things/Pawn/Humanlike/Armor/LightArmor/LightArmor</wornGraphicPath>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Shoulders</li>
        <li>Neck</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <shellRenderedBehindHead>True</shellRenderedBehindHead>
      <layers>
        <li>Middle</li>
        <li>Shell</li>
      </layers>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
      <soundWear>Wear_PowerArmor</soundWear>
      <soundRemove>Remove_PowerArmor</soundRemove>
      <tags Inherit="False">
        <li>UFR_Armor</li>
      </tags>
    </apparel>
    <techLevel>Spacer</techLevel>
    <thingCategories>
      <li>UFR_Armor</li>
    </thingCategories>
    <tradeTags>
      <li>Armor</li>
      <li>UFR_Armor</li>
    </tradeTags>
    <uiIconScale>1.15</uiIconScale>
  </ThingDef>

