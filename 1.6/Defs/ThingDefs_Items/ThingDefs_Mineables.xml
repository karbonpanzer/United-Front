<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="RockBase">
    <defName>UFR_MineableCeramium</defName>
    <label>ceramium deposit</label>
    <description>Ancient building material, compacted over time. Can be mined for ceramium.</description>
    <graphicData>
      <texPath>Things/Building/Linked/RockFlecked_Atlas</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <color>(180,170,150)</color>
      <colorTwo>(210,195,165)</colorTwo>
    </graphicData>
    <statBases>
      <MaxHitPoints>2000</MaxHitPoints>
    </statBases>
    <building>
      <isResourceRock>true</isResourceRock>
      <mineableThing>UFR_Ceramium</mineableThing>
      <mineableYield>30</mineableYield>
      <mineableScatterCommonality>0.10</mineableScatterCommonality>
      <mineableScatterLumpSizeRange>2~8</mineableScatterLumpSizeRange>
      <veinMineable>true</veinMineable>
    </building>
  </ThingDef>

</Defs>
