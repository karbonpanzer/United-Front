<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="ResourceBase">
    <defName>UFR_Ceramium</defName>
    <label>ceramium</label>
    <description>A manufactured ceramic compound. While not ideal for structures, some though prefer it for its simplicity in the field of art. Its primary usage is the construction of ceramite.</description>
    <graphicData>
      <texPath>Things/Item/Resource/Ceramium</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Stone_Drop</soundInteract>
    <soundDrop>Stone_Drop</soundDrop>
    <useHitPoints>true</useHitPoints>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <MarketValue>4.5</MarketValue>
      <Mass>0.5</Mass>
      <Flammability>0</Flammability>
      <DeteriorationRate>0</DeteriorationRate>
      <Beauty>1</Beauty>
      <StuffPower_Armor_Sharp>0.60</StuffPower_Armor_Sharp>
      <StuffPower_Armor_Blunt>0.50</StuffPower_Armor_Blunt>
      <StuffPower_Armor_Heat>0.50</StuffPower_Armor_Heat>
      <StuffPower_Insulation_Cold>3</StuffPower_Insulation_Cold>
      <StuffPower_Insulation_Heat>2</StuffPower_Insulation_Heat>
    </statBases>
    <thingCategories>
      <li>ResourcesRaw</li>
    </thingCategories>
    <stuffProps>
      <categories>
        <li>Stony</li>
      </categories>
      <commonality>0.2</commonality>
      <color>(95,110,125)</color>
      <soundImpactBullet>BulletImpact_Ground</soundImpactBullet>
      <soundMeleeHitSharp>MeleeHit_Stone</soundMeleeHitSharp>
      <soundMeleeHitBlunt>MeleeHit_Stone</soundMeleeHitBlunt>
      <soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Stone</soundImpactMelee>
      <stuffAdjective>ceramium</stuffAdjective>
      <statFactors>
        <MaxHitPoints>0.85</MaxHitPoints>
        <Beauty>1.0</Beauty>
        <WorkToMake>0.9</WorkToMake>
      </statFactors>
      <canSuggestUseDefaultStuff>false</canSuggestUseDefaultStuff>
    </stuffProps>
    <stackLimit>75</stackLimit>
    <healthAffectsPrice>false</healthAffectsPrice>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>UFR_Ceramite</defName>
    <label>ceramite</label>
    <description>A ceramo-metal compound often seen on Industrial worlds. Ceramite is widely used in architecture, infrastructure, and even military purposes owing to its versatility Tough, heat resistant, and able to be produced at a large scale from ceramic and steel.</description>
    <graphicData>
      <texPath>Things/Item/Resource/Ceramite</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <useHitPoints>true</useHitPoints>
    <statBases>
      <MaxHitPoints>120</MaxHitPoints>
      <MarketValue>14</MarketValue>
      <Mass>0.5</Mass>
      <Flammability>0.1</Flammability>
      <DeteriorationRate>0</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <stackLimit>75</stackLimit>
    <healthAffectsPrice>false</healthAffectsPrice>
  </ThingDef>

  <ThingDef ParentName="WoolBase">
    <defName>UFR_OvisypiumWool</defName>
    <label>ovisypium wool</label>
    <description>A plant grown wool with a soft feel, provides good insulation but not as durable as high-end wools and fibers.</description>
    <possessionCount>30</possessionCount>
    <statBases>
      <StuffPower_Insulation_Cold>28</StuffPower_Insulation_Cold>
      <StuffPower_Insulation_Heat>28</StuffPower_Insulation_Heat>
    </statBases>
    <graphicData>
      <color>(198,198,198)</color>
    </graphicData>
    <stuffProps>
      <color>(198,198,198)</color>
    </stuffProps>
  </ThingDef>

</Defs>
