<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="ResourceBase">
    <defName>UFR_DuramiumAlloy</defName>
    <label>duramium alloy</label>
    <description>A ceramo-metal compound often seen on Industrial worlds, found in naturally occurring ore veins. Duramium alloy is widely used in architecture, infrastructure, and even military purposes owing to its versatility. Tough, heat resistant, and quarried directly from spacer-era mineral deposits.</description>
    <graphicData>
      <texPath>Things/Item/Resource/DuramiumAlloy</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <useHitPoints>true</useHitPoints>
    <statBases>
      <MaxHitPoints>180</MaxHitPoints>
      <MarketValue>14</MarketValue>
      <Mass>0.5</Mass>
      <Flammability>0.1</Flammability>
      <DeteriorationRate>0</DeteriorationRate>
      <Beauty>2</Beauty>
      <StuffPower_Armor_Sharp>0.95</StuffPower_Armor_Sharp>
      <StuffPower_Armor_Blunt>0.85</StuffPower_Armor_Blunt>
      <StuffPower_Armor_Heat>0.95</StuffPower_Armor_Heat>
      <StuffPower_Insulation_Cold>4</StuffPower_Insulation_Cold>
      <StuffPower_Insulation_Heat>6</StuffPower_Insulation_Heat>
    </statBases>
    <thingCategories>
      <li>ResourcesRaw</li>
    </thingCategories>
    <stuffProps>
      <categories>
        <li>Stony</li>
      </categories>
      <commonality>0.1</commonality>
      <color>(110,102,90)</color>
      <soundImpactBullet>BulletImpact_Metal</soundImpactBullet>
      <soundMeleeHitSharp>MeleeHit_Metal</soundMeleeHitSharp>
      <soundMeleeHitBlunt>MeleeHit_Metal</soundMeleeHitBlunt>
      <soundImpactMelee>Pawn_Melee_Punch_HitBuilding_Metal</soundImpactMelee>
      <stuffAdjective>duramium</stuffAdjective>
      <statFactors>
        <MaxHitPoints>1.5</MaxHitPoints>
        <Beauty>1.2</Beauty>
        <WorkToMake>0.8</WorkToMake>
        <Flammability>0.6</Flammability>
      </statFactors>
      <canSuggestUseDefaultStuff>false</canSuggestUseDefaultStuff>
    </stuffProps>
    <stackLimit>75</stackLimit>
    <healthAffectsPrice>false</healthAffectsPrice>
  </ThingDef>

  <ThingDef ParentName="WoolBase">
    <defName>UFR_FlufflonWool</defName>
    <label>flufflon wool</label>
    <description>Surprisingly soft wool of a flufflon. It is a great insulator and fetches a high price.</description>
    <possessionCount>30</possessionCount>
    <statBases>
      <MarketValue>4.5</MarketValue>
      <StuffPower_Armor_Blunt>0.15</StuffPower_Armor_Blunt>
      <StuffPower_Insulation_Cold>32</StuffPower_Insulation_Cold>
      <StuffPower_Insulation_Heat>30</StuffPower_Insulation_Heat>
    </statBases>
    <stuffProps>
      <color>(105,110,115)</color>
      <commonality>0.20</commonality>
    </stuffProps>
    <graphicData>
      <texPath>Things/Item/Resource/Wool</texPath>
      <color>(105,110,115)</color>
    </graphicData>
  </ThingDef>

  <ThingDef ParentName="LeatherBase">
    <defName>UFR_FlufflonLeather</defName>
    <label>flufflon hide</label>
    <description>Tanned, dried, and scraped flufflon skin. Tough but lacking in insulation.</description>
    <possessionCount>20</possessionCount>
    <graphicData>
      <color>(105,110,115)</color>
    </graphicData>
    <statBases>
      <MarketValue>2.8</MarketValue>
      <StuffPower_Armor_Sharp>1.10</StuffPower_Armor_Sharp>
      <StuffPower_Armor_Blunt>0.30</StuffPower_Armor_Blunt>
      <StuffPower_Insulation_Cold>8</StuffPower_Insulation_Cold>
      <StuffPower_Insulation_Heat>8</StuffPower_Insulation_Heat>
    </statBases>
    <stuffProps>
      <color>(105,110,115)</color>
      <commonality>0.05</commonality>
      <statFactors>
        <MaxHitPoints>1.3</MaxHitPoints>
        <Beauty>1.2</Beauty>
      </statFactors>
    </stuffProps>
  </ThingDef>
</Defs>