<?xml version='1.0' encoding='utf-8'?>
<Defs>

	<!-- Refugees - Player Faction-->

	<FactionDef ParentName="PlayerFactionBase">
		<defName>DRG_Player</defName>
		<label>Ringer settlers</label>
		<description>A colony of citizens from a dead orbital ring station.</description>
		<colorSpectrum>
            <li>(0, 0.737, 0.847)</li>
		</colorSpectrum>
		<isPlayer>true</isPlayer>
		<basicMemberKind>DRG_Player</basicMemberKind>
		<pawnSingular>ringer</pawnSingular>
		<pawnsPlural>ringers</pawnsPlural>
		<techLevel>Spacer</techLevel>
		<allowedCultures>
			<li>Astropolitan</li>
		</allowedCultures>
		<factionNameMaker>DRG_Faction_Civil</factionNameMaker>
		<settlementNameMaker>DRG_Settlement_Civil</settlementNameMaker>
		<backstoryFilters>
		  <li>
			<categories>
				<li>Outlander</li>
			</categories>
		  </li>
		</backstoryFilters>
		<apparelStuffFilter>
			<thingDefs>
				<li>Synthread</li>
			</thingDefs>
		</apparelStuffFilter>
		<factionIconPath>UI/FactionIcons/DominionPlayerHome</factionIconPath>
		<startingResearchTags>
			<li>ClassicStart</li>
		</startingResearchTags>
		<startingTechprintsResearchTags>
			<li>ClassicStart</li>
			<li>ClassicStartTechprints</li>
		</startingTechprintsResearchTags>
	</FactionDef>

	<!-- Colonists - Civil Faction-->

	<FactionDef ParentName="FactionBase">
		<defName>DRG_Civil</defName>
		<label>Ringer settlers</label>
		<description>Refugees of a dead orbital ring from a nearby system. After their home fell many found themselves as refugees settling on the Rimworlds around them.\n\nThough they lack many pieces of technology from their former home. They still retain their technology, composite armor, advanced weaponry, and secretive technology not availiable  to outsiders. A strong spacer faction using technology which favors collective over the individual, they are not powerful but have numbers on their side.\n\nStrong, resilient, and charitable, they make for great allies and worse enemies.</description>
		<pawnSingular>ringer</pawnSingular>
		<pawnsPlural>ringers</pawnsPlural>
		<listOrderPriority>13</listOrderPriority>
		<settlementGenerationWeight>1</settlementGenerationWeight>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxCountAtGameStart>1</maxCountAtGameStart>
		<canMakeRandomly>true</canMakeRandomly>
		<canSiege>true</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<leaderTitle>governor</leaderTitle>
		<factionIconPath>UI/FactionIcons/Dominion</factionIconPath>
		<factionNameMaker>DRG_Faction_Civil</factionNameMaker>
		<settlementNameMaker>DRG_Settlement_Civil</settlementNameMaker>
		<colorSpectrum>
			<li>(0.80, 0.80, 0.95)</li>
		</colorSpectrum>
		<permanentEnemy>false</permanentEnemy>
		<techLevel>Spacer</techLevel>
		<allowedCultures>
			<li>Astropolitan</li>
		</allowedCultures>
		<requiredMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Individualist</li>			
		</requiredMemes>
		<disallowedMemes>
			<li MayRequire="Ludeon.RimWorld.Ideology">Raider</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Supremacist</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">Cannibal</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">TreeConnection</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">AnimalPersonhood</li>
		</disallowedMemes>
		<backstoryFilters>
			<li>
				<categories>
					<li>Outlander</li>
					<li>Pirate</li>
				</categories>
			</li>
		</backstoryFilters>
		<xenotypeSet>
			<xenotypeChances>
				<Hussar MayRequire="Ludeon.RimWorld.Biotech">0.12</Hussar>
				<Dirtmole MayRequire="Ludeon.RimWorld.Biotech">0.06</Dirtmole>
				<Impid MayRequire="Ludeon.RimWorld.Biotech">0.02</Impid>
				<Genie MayRequire="Ludeon.RimWorld.Biotech">0.08</Genie>
				<Yttakin MayRequire="Ludeon.RimWorld.Biotech">0.02</Yttakin>
			</xenotypeChances>
		</xenotypeSet>
		<allowedArrivalTemperatureRange>-40~50</allowedArrivalTemperatureRange>
		<raidLootMaker>OutlanderRaidLootMaker</raidLootMaker>
		<caravanTraderKinds>
			<li>Caravan_Ringer_BulkGoods</li>
			<li>Caravan_Ringer_ArmsDealer</li>
			<li>Caravan_Ringer_Exotic</li>
		</caravanTraderKinds>
		<visitorTraderKinds>
			<li>Visitor_Ringer_Standard</li>
		</visitorTraderKinds>
		<baseTraderKinds>
			<li>Base_Ringer_Standard</li>
		</baseTraderKinds>
		<maxPawnCostPerTotalPointsCurve>
			<points>
				<li>(0, 40)</li>
				<li>(70, 60)</li>
				<li>(700, 120)</li>
				<li>(1300, 200)</li>
				<li>(100000,10000)</li>
			</points>
		</maxPawnCostPerTotalPointsCurve>
		<pawnGroupMakers>
			<!-- Combat Group 1: Mixed forces with ranged and melee -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>45</commonality>
				<options>
					<DRG_Civil_Recruit_Ranged>5</DRG_Civil_Recruit_Ranged>
					<DRG_Civil_Recruit_Melee>3</DRG_Civil_Recruit_Melee>
					<DRG_Civil_Infantry_Ranged>12</DRG_Civil_Infantry_Ranged>
					<DRG_Civil_Infantry_Melee>6</DRG_Civil_Infantry_Melee>
					<DRG_Civil_Veteran_Ranged>8</DRG_Civil_Veteran_Ranged>
					<DRG_Civil_Veteran_Melee>5</DRG_Civil_Veteran_Melee>
					<DRG_Civil_Sergeant>4</DRG_Civil_Sergeant>
					<DRG_Civil_Ranger>7</DRG_Civil_Ranger>
					<DRG_Civil_GrenadierFrag>3</DRG_Civil_GrenadierFrag>
					<DRG_Civil_GrenadierEMP>3</DRG_Civil_GrenadierEMP>
					<DRG_Civil_GrenadierFire>3</DRG_Civil_GrenadierFire>
