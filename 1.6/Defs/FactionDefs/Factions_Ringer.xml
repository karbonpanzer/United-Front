					<DRG_Civil_Shocktrooper>2</DRG_Civil_Shocktrooper>
					<DRG_Civil_Medic>3</DRG_Civil_Medic>
					<DRG_Civil_Engineer>3</DRG_Civil_Engineer>
					<DRG_Civil_Warden>2</DRG_Civil_Warden>
					<DRG_Civil_Officer>3</DRG_Civil_Officer>
				</options>
			</li>

			<!-- Combat Group 2: Standard raid composition -->
			<li>
				<kindDef>Combat</kindDef>
				<commonality>35</commonality>
				<options>
					<DRG_Civil_Recruit_Ranged>8</DRG_Civil_Recruit_Ranged>
					<DRG_Civil_Recruit_Melee>5</DRG_Civil_Recruit_Melee>
					<DRG_Civil_Infantry_Ranged>20</DRG_Civil_Infantry_Ranged>
					<DRG_Civil_Infantry_Melee>10</DRG_Civil_Infantry_Melee>
					<DRG_Civil_Sergeant>5</DRG_Civil_Sergeant>
					<DRG_Civil_Medic>8</DRG_Civil_Medic>
					<DRG_Civil_Engineer>8</DRG_Civil_Engineer>
					<DRG_Civil_Officer>3</DRG_Civil_Officer>
				</options>
			</li>

			<!-- Peaceful Group -->
			<li>
				<kindDef>Peaceful</kindDef>
				<commonality>20</commonality>
				<options>
					<DRG_Civil_Settler>12</DRG_Civil_Settler>
					<DRG_Civil_Laborer>8</DRG_Civil_Laborer>
					<DRG_Civil_Trader>8</DRG_Civil_Trader>
					<DRG_Civil_Representative>2</DRG_Civil_Representative>
					<DRG_Civil_Ranger>4</DRG_Civil_Ranger>
					<DRG_Civil_Infantry_Ranged>4</DRG_Civil_Infantry_Ranged>
					<DRG_Civil_Infantry_Melee>2</DRG_Civil_Infantry_Melee>
					<DRG_Civil_Medic>2</DRG_Civil_Medic>
					<DRG_Civil_Engineer>2</DRG_Civil_Engineer>
					<DRG_Civil_Officer>1</DRG_Civil_Officer>
				</options>
			</li>

			<!-- Trader Group -->
			<li>
				<kindDef>Trader</kindDef>
				<traders>
					<DRG_Civil_Trader>1</DRG_Civil_Trader>
				</traders>
				<carriers>
					<Muffalo>6</Muffalo>
					<Dromedary>5</Dromedary>
					<Alpaca>2</Alpaca>
					<Elephant>1</Elephant>
				</carriers>
				<guards>
					<DRG_Civil_Infantry_Ranged>4</DRG_Civil_Infantry_Ranged>
					<DRG_Civil_Infantry_Melee>2</DRG_Civil_Infantry_Melee>
					<DRG_Civil_Ranger>4</DRG_Civil_Ranger>
					<DRG_Civil_Sergeant>2</DRG_Civil_Sergeant>
					<DRG_Civil_Officer>1</DRG_Civil_Officer>
				</guards>
			</li>

			<!-- Settlement Group -->
			<li>
				<kindDef>Settlement</kindDef>
				<options>
					<DRG_Civil_Settler>20</DRG_Civil_Settler>
					<DRG_Civil_Laborer>12</DRG_Civil_Laborer>
					<DRG_Civil_Engineer>4</DRG_Civil_Engineer>
					<DRG_Civil_Medic>4</DRG_Civil_Medic>
					<DRG_Civil_Infantry_Ranged>6</DRG_Civil_Infantry_Ranged>
					<DRG_Civil_Infantry_Melee>2</DRG_Civil_Infantry_Melee>
					<DRG_Civil_Ranger>6</DRG_Civil_Ranger>
					<DRG_Civil_Representative>1</DRG_Civil_Representative>
					<DRG_Civil_Officer>3</DRG_Civil_Officer>
				</options>
			</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">
				<kindDef>Miners</kindDef>
				<commonality>1</commonality>
				<options>
					<Miner>1</Miner>
				</options>
			</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">
				<kindDef>Hunters</kindDef>
				<commonality>1</commonality>
				<options>
					<Hunter>1</Hunter>
				</options>
			</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">
				<kindDef>Loggers</kindDef>
				<commonality>1</commonality>
				<options>
					<Logger>1</Logger>
				</options>
			</li>
			<li MayRequire="Ludeon.RimWorld.Ideology">
				<kindDef>Farmers</kindDef>
				<commonality>1</commonality>
				<options>
					<Farmer>1</Farmer>
				</options>
			</li>			
		</pawnGroupMakers>
		<settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
		<maxConfigurableAtWorldCreation>9999</maxConfigurableAtWorldCreation>
		<configurationListOrderPriority>25</configurationListOrderPriority>
	</FactionDef>	

	<!-- Freelancers - Hostile Faction-->

	<FactionDef ParentName="FactionBase">
		<defName>DRG_Rough</defName>
		<label>Ringer outcasts</label>
		<description>After the collapse of their home, many of the predatorory factions of the orbital station banded together as pirates.\n\nServing no one but themselves, they raided worlds, selling their services to the highest bidders. Their technology despite their riches, has not advanced, still using their technology they arrived with.\n\nWithout honor or consciousness, they prey on all those they are near.</description>
		<pawnSingular>outcast</pawnSingular>
		<pawnsPlural>outcasts</pawnsPlural>
		<listOrderPriority>13</listOrderPriority>
		<settlementGenerationWeight>1</settlementGenerationWeight>
		<requiredCountAtGameStart>1</requiredCountAtGameStart>
		<maxCountAtGameStart>1</maxCountAtGameStart>
		<canMakeRandomly>true</canMakeRandomly>
		<canSiege>true</canSiege>
		<canStageAttacks>true</canStageAttacks>
		<leaderTitle>boss</leaderTitle>
		<factionIconPath>UI/FactionIcons/Freelancers</factionIconPath>
		<factionNameMaker>NamerFactionPirate</factionNameMaker>
		<settlementNameMaker>NamerSettlementPirate</settlementNameMaker>
		<colorSpectrum>
			<li>(0.60, 0.15, 0.15)</li>
		</colorSpectrum>
