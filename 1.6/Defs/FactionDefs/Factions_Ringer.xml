<Defs>

	<FactionDef ParentName="PlayerFactionBase">
		<defName>DRG_Player</defName>
		<label>Outcast refugees</label>
		<description>A small group of war refugees displaced from a fallen industrial world. Armed with whatever Imperial gear they could salvage during the evacuation, they have arrived on this rimworld with the desperate hope of building a stable new home.</description>
		<colorSpectrum>
            <li>(0, 0.737, 0.847)</li>
		</colorSpectrum>
		<isPlayer>true</isPlayer>
		<basicMemberKind>DRG_Player</basicMemberKind>
		<pawnSingular>outcast</pawnSingular>
		<pawnsPlural>outcasts</pawnsPlural>
		<techLevel>Spacer</techLevel>
		<allowedCultures>
			<li>Astropolitan</li>
		</allowedCultures>
		<factionNameMaker>DRG_Faction_Civil</factionNameMaker>
		<settlementNameMaker>NamerSettlementOutlander</settlementNameMaker>
		<backstoryFilters>
		  <li>
			<categories>
				<li>Outlander</li>
			</categories>
		  </li>
		</backstoryFilters>
		<apparelStuffFilter>
			<thingDefs>
				<li>Synthread</li>
			</thingDefs>
		</apparelStuffFilter>
		<factionIconPath>UI/FactionIcons/DominionPlayerHome</factionIconPath>
		<startingResearchTags>
			<li>ClassicStart</li>
		</startingResearchTags>
		<startingTechprintsResearchTags>
			<li>ClassicStart</li>
			<li>ClassicStartTechprints</li>
		</startingTechprintsResearchTags>
	</FactionDef>

	<FactionDef ParentName="FactionBase">
		<defName>DRG_Civil</defName>
