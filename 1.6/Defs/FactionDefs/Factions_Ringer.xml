		<defName>DRG_Player</defName>
		<label>Outcast refugees</label>
		<description>A colony of war refugees displaced from a fallen industrial world that the Empire could no longer defend. They carry whatever Imperial gear they could evacuate with, and the will to build something stable on the rim.</description>
		<colorSpectrum>
            <li>(0, 0.737, 0.847)</li>
		</colorSpectrum>
		<isPlayer>true</isPlayer>
		<basicMemberKind>DRG_Player</basicMemberKind>
		<pawnSingular>outcast</pawnSingular>
		<pawnsPlural>outcasts</pawnsPlural>
