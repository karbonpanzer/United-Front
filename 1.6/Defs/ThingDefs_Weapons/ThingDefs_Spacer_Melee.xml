<Defs>

	<ThingDef ParentName="BaseMeleeWeapon_Sharp_Quality">
		<defName>DITN_Vibrosword</defName>
		<label>Vibrosword</label>
		<description>A composite sword powered by a small micro-motor which vibrates the blade. Easily able to carve through armor and flesh, the production of it is a closely guarded secret in the Dominion.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Things/Item/Equipment/WeaponMelee/vibrosword</texPath>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>1.4</drawSize>
		</graphicData>
		<techLevel>Spacer</techLevel>
		<equippedAngleOffset>-50</equippedAngleOffset>
		<recipeMaker>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Smith</soundWorking>
			<researchPrerequisite>DITN_VibroWeapons</researchPrerequisite>
			<skillRequirements>
				<Crafting>10</Crafting>
			</skillRequirements>
			<recipeUsers>
				<li>DITN_FabricationBench</li>
			</recipeUsers>
		</recipeMaker>
		<costList>
			<Steel>40</Steel>
			<ComponentIndustrial>3</ComponentIndustrial>
			<ComponentSpacer>3</ComponentSpacer>
			<Plasteel>15</Plasteel>
		</costList>
		<statBases>
			<WorkToMake>36000</WorkToMake>
			<Mass>1.6</Mass>
			<MarketValue>3600</MarketValue>
		</statBases>
		<tools>
			<li>
				<label>handle</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2.4</cooldownTime>
			</li>
			<li>
				<label>edge</label>
				<capacities>
					<li>Cut</li>
				</capacities>
				<power>26</power>
				<cooldownTime>2.4</cooldownTime>
				<armorPenetration>0.50</armorPenetration>
			</li>
			<li>
				<label>point</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>24</power>
				<cooldownTime>2.4</cooldownTime>
				<armorPenetration>0.50</armorPenetration>
			</li>
		</tools>
		<weaponTags>
			<li>DITN_OutcastMelee</li>
			<li>DITN_OutcastEliteMelee</li>
		</weaponTags>
		<thingSetMakerTags>
			<li>RewardHighTech</li>
