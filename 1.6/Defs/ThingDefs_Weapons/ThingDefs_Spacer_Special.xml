		<techLevel>Spacer</techLevel>
		<soundInteract>Interact_Rifle</soundInteract>
		<recipeMaker>
			<researchPrerequisite>DRG_MercenaryWeaponry</researchPrerequisite>
			<skillRequirements>
				<Crafting>9</Crafting>
