<?xml version="1.0" encoding="utf-8"?>
<Defs>

<ThingDef ParentName="BuildingBase">
  <defName>FoodSynthesizer</defName>
  <label>food synthesizer</label>
  <description>An advanced molecular assembly unit that synthesizes edible food cubes from atmospheric compounds. A selection dial allows the operator to choose the output type. The machine hums with quiet purpose — utilitarian, reliable, and deeply unappetizing.</description>
  <thingClass>Building</thingClass>
  <graphicData>
    <texPath>Things/Building/Special/FoodSynthesizer</texPath>
    <graphicClass>Graphic_Single</graphicClass>
    <drawSize>(3, 3)</drawSize>
    <shadowData>
      <volume>(1.8, 1.0, 0.2)</volume>
      <offset>(0.0, 0.0, -0.4)</offset>
    </shadowData>
  </graphicData>
  <thingCategories>
    <li>BuildingsSpecial</li>
  </thingCategories>
  <costList>
    <Steel>250</Steel>
    <ComponentSpacer>6</ComponentSpacer>
  </costList>
  <building>
    <destroySound>BuildingDestroyed_Metal_Big</destroySound>
  </building>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>350</basePowerConsumption>
      </li>
      <li Class="FoodSynthesizer.CompProperties_SpawnerSelectable">
        <spawnOptions>                                  
          <DRG_Meatcube>75</DRG_Meatcube>
          <DRG_Vegblock>75</DRG_Vegblock>
          <DRG_Fruitblock>75</DRG_Fruitblock>
          <DRG_Chocoblock>50</DRG_Chocoblock>
        </spawnOptions>
        <spawnIntervalRange>100000~100000</spawnIntervalRange>
        <spawnMaxAdjacent>-1</spawnMaxAdjacent>
        <requiresPower>true</requiresPower>
        <writeTimeLeftToSpawn>true</writeTimeLeftToSpawn>
        <showMessageIfOwned>true</showMessageIfOwned>
        <saveKeysPrefix>foodSynth</saveKeysPrefix>
      </li>
    </comps>
  <altitudeLayer>Building</altitudeLayer>
  <statBases>
    <MarketValue>1800</MarketValue>
    <MaxHitPoints>200</MaxHitPoints>
    <Flammability>0.5</Flammability>
    <Beauty>-5</Beauty>
    <Mass>40</Mass>
    <WorkToBuild>10000</WorkToBuild>
  </statBases>
  <thingSetMakerTags>
    <li>RewardStandardCore</li>
  </thingSetMakerTags>
  <tickerType>Normal</tickerType>
  <size>(1, 1)</size>
  <fillPercent>1.0</fillPercent>
  <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
  <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
  <passability>Impassable</passability>
  <rotatable>false</rotatable>
  <canOverlapZones>false</canOverlapZones>
  <minifiedDef>MinifiedThing</minifiedDef>
  <tradeability>Sellable</tradeability>
  <tradeTags>
    <li>ExoticBuilding</li>
  </tradeTags>
</ThingDef>

</Defs>