<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="PlantBase">
    <defName>UFR_OvisypiumPlant</defName>
    <label>ovisypium plant</label>
    <description>This plant was genetically engineered from cotton plants by vegan groups to produce a dense wool for usage on their colonies. While it takes a long time to grow, the wool it produces is great for both extreme heat and cold.

Despite its origins, it has approximately 1.5% sheep DNA. Making the harvesting of it technically non-vegan.</description>
    <statBases>
      <MaxHitPoints>85</MaxHitPoints>
      <Nutrition>0.2</Nutrition>
    </statBases>
    <graphicData>
      <texPath>Things/Plant/CottonPlant</texPath>
      <graphicClass>Graphic_Random</graphicClass>
    </graphicData>
    <selectable>true</selectable>
    <pathCost>14</pathCost>
    <ingestible />
    <plant>
      <fertilityMin>0.80</fertilityMin>
      <fertilitySensitivity>0.7</fertilitySensitivity>
      <sowWork>300</sowWork>
      <harvestWork>900</harvestWork>
      <growDays>25</growDays>
      <harvestYield>2</harvestYield>
      <harvestedThingDef>UFR_OvisypiumWool</harvestedThingDef>
      <harvestTag>Standard</harvestTag>
      <sowMinSkill>6</sowMinSkill>
      <sowTags>
        <li>Ground</li>
        <li>Hydroponic</li>
      </sowTags>
      <topWindExposure>0.2</topWindExposure>
      <visualSizeRange>0.45~1.05</visualSizeRange>
      <wildOrder>2</wildOrder>
      <dieIfLeafless>false</dieIfLeafless>
      <purpose>Beauty</purpose>
    </plant>
  </ThingDef>

</Defs>
