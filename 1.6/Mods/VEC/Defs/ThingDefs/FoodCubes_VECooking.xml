<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ===================== SQUARELOAF ===================== -->
  <ThingDef ParentName="FoodCubeBase">
    <defName>DRG_Squareloaf</defName>
    <label>squareloaf</label>
    <description>A pale, dense cube of synthesized grain starch. Functionally identical to flour for baking purposes, though no wheat was harmed in its production. Has the texture of stale bread and the personality to match.</description>
    <graphicData>
      <texPath>Things/Item/Food/Squareloaf</texPath>
    </graphicData>
    <soundInteract>Grain_Drop</soundInteract>
    <soundDrop>Grain_Drop</soundDrop>
    <statBases>
      <MarketValue>1.0</MarketValue>
      <Nutrition>0.05</Nutrition>
      <Flammability>1.3</Flammability>
    </statBases>
    <comps>
      <li Class="CompProperties_Forbiddable" />
      <li Class="CompProperties_Rottable">
        <daysToRotStart>100</daysToRotStart>
        <rotDestroys>true</rotDestroys>
      </li>
    </comps>
    <ingestible>
      <preferability>NeverForNutrition</preferability>
    </ingestible>
    <thingCategories>
      <li>PlantMatter</li>
    </thingCategories>
  </ThingDef>

  <!-- ===================== SEASONCUBE ===================== -->
  <ThingDef ParentName="FoodCubeBase">
    <defName>DRG_Seasoncube</defName>
    <label>seasoncube</label>
    <description>A tiny, potent cube of synthesized spices and flavoring compounds. Adds complexity to cooked meals. Eating one raw is an experience most colonists prefer not to repeat.</description>
    <graphicData>
      <texPath>Things/Item/Food/Seasoncube</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1.3</MarketValue>
      <Nutrition>0.01</Nutrition>
      <Flammability>1.3</Flammability>
    </statBases>
    <comps>
      <li Class="CompProperties_Forbiddable" />
      <li Class="CompProperties_Rottable">
        <daysToRotStart>120</daysToRotStart>
        <rotDestroys>true</rotDestroys>
      </li>
    </comps>
    <ingestible>
      <foodType>VegetableOrFruit</foodType>
      <preferability>NeverForNutrition</preferability>
      <specialThoughtAsIngredient>VCE_ConsumedSpices</specialThoughtAsIngredient>
      <optimalityOffsetFeedingAnimals>-50</optimalityOffsetFeedingAnimals>
    </ingestible>
    <thingCategories>
      <li>VCE_Condiments</li>
    </thingCategories>
    <ingredient>
      <mergeCompatibilityTags>
        <li>Condiments</li>
      </mergeCompatibilityTags>
    </ingredient>
  </ThingDef>

</Defs>
