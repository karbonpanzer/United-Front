<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ===================== ABSTRACT BASE ===================== -->
  <ThingDef Name="FoodCubeBase" Abstract="True">
    <thingClass>ThingWithComps</thingClass>
    <category>Item</category>
    <drawerType>MapMeshOnly</drawerType>
    <resourceReadoutPriority>Middle</resourceReadoutPriority>
    <useHitPoints>true</useHitPoints>
    <selectable>true</selectable>
    <altitudeLayer>Item</altitudeLayer>
    <stackLimit>75</stackLimit>
    <tickerType>Rare</tickerType>
    <drawGUIOverlay>true</drawGUIOverlay>
    <socialPropernessMatters>true</socialPropernessMatters>
    <alwaysHaulable>true</alwaysHaulable>
    <pathCost>14</pathCost>
    <allowedArchonexusCount>40</allowedArchonexusCount>
    <comps>
      <li Class="CompProperties_Forbiddable" />
      <li Class="CompProperties_Rottable">
        <daysToRotStart>30</daysToRotStart>
        <rotDestroys>true</rotDestroys>
      </li>
    </comps>
    <graphicData>
      <graphicClass>Graphic_StackCount</graphicClass>
      <drawSize>0.88</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <Flammability>0.5</Flammability>
      <Beauty>-4</Beauty>
      <DeteriorationRate>10</DeteriorationRate>
      <Mass>0.03</Mass>
    </statBases>
    <thingCategories>
      <li>Foods</li>
    </thingCategories>
    <ingestible>
      <foodType>Meal</foodType>
      <preferability>RawBad</preferability>
      <ingestEffect>EatVegetarian</ingestEffect>
      <ingestSound>RawVegetable_Eat</ingestSound>
      <tasteThought>AteRawFood</tasteThought>
      <optimalityOffsetHumanlikes>-20</optimalityOffsetHumanlikes>
      <optimalityOffsetFeedingAnimals>-10</optimalityOffsetFeedingAnimals>
    </ingestible>
  </ThingDef>

  <ThingDef ParentName="FoodCubeBase">
    <defName>DRG_Meatcube</defName>
    <label>meatcube</label>
    <description>A dense, pinkish cube of synthesized protein. Technically edible raw, but really meant to be cooked. Tastes vaguely of everything and nothing at the same time.</description>
    <graphicData>
      <texPath>Things/Item/Food/Meatcube</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1.2</MarketValue>
      <Nutrition>0.05</Nutrition>
    </statBases>
    <ingestible>
      <foodType>Meat</foodType>
      <ingestEffect>EatMeat</ingestEffect>
      <ingestSound>Meal_Eat</ingestSound>
      <tasteThought>AteRawFood</tasteThought>
    </ingestible>
    <thingCategories>
      <li>MeatRaw</li>
    </thingCategories>
  </ThingDef>

  <ThingDef ParentName="FoodCubeBase">
    <defName>DRG_Vegblock</defName>
    <label>vegblock</label>
    <description>A firm green cube of compressed plant matter. All the nutrition of vegetables, none of the flavor. Colonists will eat it, but they won't be happy about it.</description>
    <graphicData>
      <texPath>Things/Item/Food/Vegblock</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1.0</MarketValue>
      <Nutrition>0.05</Nutrition>
    </statBases>
    <ingestible>
      <foodType>VegetableOrFruit</foodType>
      <ingestEffect>EatVegetarian</ingestEffect>
      <ingestSound>RawVegetable_Eat</ingestSound>
    </ingestible>
    <thingCategories>
      <li>PlantFoodRaw</li>
    </thingCategories>
  </ThingDef>

  <ThingDef ParentName="FoodCubeBase">
    <defName>DRG_Fruitblock</defName>
    <label>fruitblock</label>
    <description>A soft, slightly sweet cube of synthesized fruit compounds. The most tolerable of the food cubes when eaten raw. Still unmistakably artificial.</description>
    <graphicData>
      <texPath>Things/Item/Food/Fruitblock</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1.1</MarketValue>
      <Nutrition>0.05</Nutrition>
    </statBases>
    <ingestible>
      <foodType>VegetableOrFruit</foodType>
      <preferability>RawTasty</preferability>
      <ingestEffect>EatVegetarian</ingestEffect>
      <ingestSound>RawVegetable_Eat</ingestSound>
      <tasteThought />
    </ingestible>
    <thingCategories>
      <li>PlantFoodRaw</li>
    </thingCategories>
  </ThingDef>

  <ThingDef ParentName="FoodCubeBase">
    <defName>DRG_Chocoblock</defName>
    <label>chocoblock</label>
    <description>A dark brown cube of synthesized cocoa compounds. Sweet enough to eat on its own and useful as a cooking ingredient. A small luxury from a machine.</description>
    <graphicData>
      <texPath>Things/Item/Food/Chocoblock</texPath>
    </graphicData>
    <statBases>
      <MarketValue>1.5</MarketValue>
      <Nutrition>0.1</Nutrition>
    </statBases>
    <ingestible>
      <foodType>VegetableOrFruit</foodType>
      <preferability>RawTasty</preferability>
      <joy>0.08</joy>
      <joyKind>Gluttonous</joyKind>
      <ingestEffect>EatVegetarian</ingestEffect>
      <ingestSound>Meal_Eat</ingestSound>
      <tasteThought />
    </ingestible>
    <thingCategories>
      <li>PlantFoodRaw</li>
    </thingCategories>
  </ThingDef>

</Defs>
